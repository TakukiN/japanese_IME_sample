<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
      セキュリティ方針（OWASP MASVS）:
      - INTERNET 権限を宣言しない = 入力内容の外部送信は不可能（完全オンデバイス）。
      - allowBackup=false / dataExtractionRules で学習・辞書データのバックアップ/転送を禁止。
      - usesCleartextTraffic=false で平文通信を禁止（防御的多重化）。
    -->
    <application
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:usesCleartextTraffic="false"
        android:label="@string/app_name"
        android:supportsRtl="true">

        <!-- オープンソースライセンス表示（IME設定 兼 ランチャー） -->
        <activity
            android:name=".LicensesActivity"
            android:label="@string/licenses_title"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 日本語IME本体（InputMethodService） -->
        <service
            android:name=".JapaneseImeService"
            android:label="@string/ime_name"
            android:permission="android.permission.BIND_INPUT_METHOD"
            android:exported="true">
            <intent-filter>
                <action android:name="android.view.InputMethod" />
            </intent-filter>
            <meta-data
                android:name="android.view.im"
                android:resource="@xml/method" />
        </service>

    </application>
</manifest>
